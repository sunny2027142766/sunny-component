{
  "name": "sunny-demo",
  "private": true,
  "version": "0.2.0",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "pnpm --filter @sunny/web dev",
    "dev:docs": "pnpm --filter @sunny/docs dev",
    "dev:all": "turbo run dev --parallel --continue --filter=@sunny/web --filter=@sunny/docs",
    "build": "turbo run build --filter=@sunny/ui --filter=@sunny/web",
    "build:docs": "pnpm --filter @sunny/docs build",
    "lint": "eslint . --ext .js,.mjs,.cjs,.ts,.vue",
    "lint:fix": "eslint . --ext .js,.mjs,.cjs,.ts,.vue --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "turbo run typecheck",
    "preview": "pnpm --filter @sunny/web preview",
    "preview:docs": "pnpm --filter @sunny/docs preview"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.20",
    "typescript-eslint": "^8.57.2",
    "vue-eslint-parser": "^10.4.0"
  }
}
