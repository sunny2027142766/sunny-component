{
  "name": "grid-edit-demo",
  "private": true,
  "version": "0.2.0",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "pnpm --filter @grid-edit/web dev",
    "dev:docs": "pnpm --filter @grid-edit/docs dev",
    "dev:all": "turbo run dev --parallel --continue --filter=@grid-edit/web --filter=@grid-edit/docs",
    "build": "turbo run build --filter=@grid-edit/ui --filter=@grid-edit/web",
    "build:docs": "pnpm --filter @grid-edit/docs build",
    "typecheck": "turbo run typecheck",
    "preview": "pnpm --filter @grid-edit/web preview",
    "preview:docs": "pnpm --filter @grid-edit/docs preview"
  },
  "devDependencies": {
    "turbo": "^2.8.20"
  }
}
