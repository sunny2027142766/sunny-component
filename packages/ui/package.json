{
  "name": "@sunny/ui",
  "version": "0.2.0",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./styles.css": "./src/styles/index.css",
    "./badge": {
      "types": "./dist/entries/badge.d.ts",
      "default": "./src/entries/badge.ts"
    },
    "./button": {
      "types": "./dist/entries/button.d.ts",
      "default": "./src/entries/button.ts"
    },
    "./input": {
      "types": "./dist/entries/input.d.ts",
      "default": "./src/entries/input.ts"
    },
    "./modal": {
      "types": "./dist/entries/modal.d.ts",
      "default": "./src/entries/modal.ts"
    },
    "./card": {
      "types": "./dist/entries/card.d.ts",
      "default": "./src/entries/card.ts"
    },
    "./table": {
      "types": "./dist/entries/table.d.ts",
      "default": "./src/entries/table.ts"
    },
    "./form": {
      "types": "./dist/entries/form.d.ts",
      "default": "./src/entries/form.ts"
    },
    "./metric-panel": {
      "types": "./dist/entries/metric-panel.d.ts",
      "default": "./src/entries/metric-panel.ts"
    },
    "./empty-panel": {
      "types": "./dist/entries/empty-panel.d.ts",
      "default": "./src/entries/empty-panel.ts"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vue/tsconfig": "^0.9.0",
    "typescript": "~5.9.3",
    "vue": "^3.5.30",
    "vue-tsc": "^3.2.5"
  }
}
