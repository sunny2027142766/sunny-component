{
  "name": "@sunny/ui",
  "version": "0.2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./badge": {
      "types": "./dist/entries/badge.d.ts",
      "default": "./dist/entries/badge.js"
    },
    "./button": {
      "types": "./dist/entries/button.d.ts",
      "default": "./dist/entries/button.js"
    },
    "./input": {
      "types": "./dist/entries/input.d.ts",
      "default": "./dist/entries/input.js"
    },
    "./modal": {
      "types": "./dist/entries/modal.d.ts",
      "default": "./dist/entries/modal.js"
    },
    "./card": {
      "types": "./dist/entries/card.d.ts",
      "default": "./dist/entries/card.js"
    },
    "./table": {
      "types": "./dist/entries/table.d.ts",
      "default": "./dist/entries/table.js"
    },
    "./form": {
      "types": "./dist/entries/form.d.ts",
      "default": "./dist/entries/form.js"
    },
    "./metric-panel": {
      "types": "./dist/entries/metric-panel.d.ts",
      "default": "./dist/entries/metric-panel.js"
    },
    "./empty-panel": {
      "types": "./dist/entries/empty-panel.d.ts",
      "default": "./dist/entries/empty-panel.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly --outDir dist && node ./scripts/postbuild.mjs",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.9.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vue": "^3.5.30",
    "vue-tsc": "^3.2.5"
  }
}
