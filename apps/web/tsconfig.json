{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "types": [
      "vite/client"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@grid-edit/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@grid-edit/ui/*": [
        "../../packages/ui/src/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.vue",
    "../../packages/ui/src/**/*.ts",
    "../../packages/ui/src/**/*.vue"
  ]
}
