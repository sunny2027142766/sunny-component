{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@sunny/ui": ["../../packages/ui/src/index.ts"],
      "@sunny/ui/*": ["../../packages/ui/src/*"],
      "@docs/*": ["./*"]
    }
  },
  "include": [
    "components/**/*.md",
    "guide/**/*.md",
    "examples/**/*.vue",
    ".vitepress/**/*.ts",
    ".vitepress/**/*.vue"
  ]
}
